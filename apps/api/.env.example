# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/acctos_ai?schema=public"

# Supabase (for Azure DI cache and processed file persistence)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Auth
JWT_SECRET="your-super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Server
PORT=5000

# HMAC secret for event ingestion
HMAC_SECRET="your-hmac-secret-for-make-webhooks"

# Document Usage API
USAGE_API_KEY="lsduy&*Shd82-SA7d1h2kxCbxb^@36K"

# Stripe (configure when ready)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OpenAI (for Excel parsing and transaction categorization)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL_EXTRACT="gpt-4o"

# Azure Document Intelligence (for PDF extraction)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://vasko.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_KEY="your-azure-document-intelligence-key"

# Mailgun email notifications (EU region, domain: support.acctos.ai)
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="support.acctos.ai"
ALERT_TEAM_EMAIL="vasil.lozev@aiassist.bg"
ALERT_CLIENT_EMAIL="vasil.lozev@aiassist.bg"

# Google OAuth (for Gmail polling + Drive upload)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# Gmail Push Notifications via Google Cloud Pub/Sub (optional, recommended)
# Format: projects/PROJECT_ID/topics/TOPIC_NAME
# Without this, the system falls back to polling every 30s
PUBSUB_TOPIC="projects/your-gcp-project/topics/gmail-acctos-push"
DRIVE_BANK_STATEMENT_FOLDER_ID="google-drive-folder-id-for-bank-statements-results"
DRIVE_BANK_STATEMENT_ORIGINALS_FOLDER_ID="google-drive-folder-id-for-bank-statements-originals"
DRIVE_VAT_FOLDER_ID="google-drive-folder-id-for-vat-results"
DRIVE_VAT_ORIGINALS_FOLDER_ID="google-drive-folder-id-for-vat-originals"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
GOOGLE_REFRESH_TOKEN="1//..."
